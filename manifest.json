{
  "manifest_version": 3,
  "name": "pAIdegua",
  "version": "1.8.1",
  "description": "Plataforma de apoio à atividade e à gestão judicial no PJe — triagem, minutas, fluxos, metas CNJ, prazos e indicadores de gestão.",
  "permissions": [
    "activeTab",
    "alarms",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.jus.br/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://kanban.paidegua.ia.br/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "pAIdegua — Assistente com IA",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.jus.br/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.jus.br/*"
      ],
      "js": ["pje-auth-page.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.jus.br/*"
      ],
      "js": ["pje-auth-probe-page.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.jus.br/*"
      ],
      "js": ["pje-auth-refresh-page.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.jus.br/*"
      ],
      "js": ["pericias-etiqueta-page.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/*"],
      "matches": [
        "https://*.jus.br/*",
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "assets/fluxos-catalogo.json",
        "assets/jornadas-jef.json",
        "assets/jornadas-ef.json",
        "assets/jornadas-comum.json"
      ],
      "matches": [
        "https://*.jus.br/*"
      ]
    }
  ]
}
